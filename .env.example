# MOSO staging base URL (no trailing slash)
# Must be MOSO's URL, distinct from check-rate which runs on :8080
MOSO_BASE_URL=https://www.viet18.com

# Path to JSON file containing MOSO auth headers (e.g. {"Authorization": "<api-key>"}
# or {"XSRF": "...", "user": "...", "Cookie": "..."}). Populated by hand —
# see docs/moso-endpoint-recon.md for the required keys.
MOSO_HEADERS_FILE=data/moso-headers.json

# Encryption passphrase for data/credentials.enc (omit to be prompted)
CHECK_RATE_PASSPHRASE=

# Comparison tolerance in price points
COMPARE_TOLERANCE=0.001
